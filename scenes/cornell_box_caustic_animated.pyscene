sceneBuilder.addMeshInstance(
    sceneBuilder.addNode(
        "Large Box",
        Transform(
            scaling=float3(0.165, 0.33, 0.165),
            translation=float3(-0.093, 0.165, -0.071),
            rotationEuler=float3(0, -1.27, 0),
        ),
    ),
    sceneBuilder.addTriangleMesh(cubeMesh, largeBox),
)

sceneBuilder.addMeshInstance(
    sceneBuilder.addNode(
        "Small Sphere",
        Transform(
            scaling=float3(0.0825, 0.0825, 0.0825),
            translation=float3(0.09, 0.0825, 0.111),
            rotationEuler=float3(0, -0.29, 0),
        ),
    ),
    sceneBuilder.addTriangleMesh(
        TriangleMesh.createFromFile("meshes/sphere.obj"), glass
    ),
)

