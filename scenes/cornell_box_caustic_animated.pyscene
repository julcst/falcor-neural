# Create camera

camera = Camera()
camera.position = float3(0, 0.275, 1.07)
camera.target = float3(0, 0.275, 0)
camera.up = float3(0, 1, 0)
camera.focalLength = 35.0
sceneBuilder.addCamera(camera)