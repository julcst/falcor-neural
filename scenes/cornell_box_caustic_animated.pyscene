# waterTransform = Transform(scaling=0.55)
# waterNodeID = sceneBuilder.addNode("Water", waterTransform)
# waterAnimation = Animation("WaterRotateAnim", waterNodeID, 10.0)
# waterAnimation.preInfinityBehavior = Animation.Behavior.Cycle
# waterAnimation.postInfinityBehavior = Animation.Behavior.Cycle
# waterAnimation.interpolationMode = Animation.InterpolationMode.Linear
# waterAnimation.enableWarping = True

# waterAnimation.addKeyframe(0.0, waterTransform)
# waterTransform.rotationEulerDeg = float3(0, 180, 0)
# waterAnimation.addKeyframe(5.0, waterTransform)

waterTransform = Transform(scaling=0.55)
waterNodeID = sceneBuilder.addNode("Water", waterTransform)

waterAnimation = Animation("WaveFlipAnim", waterNodeID, 10.0)
waterAnimation.preInfinityBehavior = Animation.Behavior.Cycle
waterAnimation.postInfinityBehavior = Animation.Behavior.Cycle
waterAnimation.interpolationMode = Animation.InterpolationMode.Linear
waterAnimation.addKeyframe(0.0, waterTransform)
waterTransform.translation.y -= 0.2
waterAnimation.addKeyframe(4.0, waterTransform)
waterAnimation.addKeyframe(5.0, waterTransform)
waterTransform.translation.y += 0.2
waterAnimation.addKeyframe(9.0, waterTransform)
waterAnimation.addKeyframe(10.0, waterTransform)

sceneBuilder.addAnimation(waterAnimation)
sceneBuilder.addMeshInstance(
    waterNodeID,
    sceneBuilder.addTriangleMesh(waterMesh, water)
)

sceneBuilder.addMeshInstance(
    sceneBuilder.addNode(
        "Light",
        Transform(
            scaling=0.02,
            translation=float3(0, 0.549, 0),
            rotationEulerDeg=float3(180, 0, 0),
        ),
    ),
    sceneBuilder.addTriangleMesh(quadMesh, light),
)

